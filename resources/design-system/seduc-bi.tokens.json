{
  "skill_name": "seduc_bi_design_system",
  "version": "1.0.0",
  "description": "Design system oficial do projeto SEDUC BI. Deve ser usado para manter login, registro, dashboard, alimentar dados, importação de planilhas e telas administrativas com o mesmo padrão visual.",
  "main_goal": "Criar todas as telas do sistema com aparência SaaS moderna, limpa, profissional, em português, com paleta azul/branco/cinza, cards arredondados, sombras suaves, sidebar fixa, dashboard com gráficos e experiência parecida com Power BI/Looker Studio simplificado.",
  "stack_context": {
    "framework": "Laravel",
    "frontend": "Blade + Livewire + Tailwind CSS",
    "interactivity": "Livewire para ações dinâmicas sem recarregar página",
    "charts": "ApexCharts",
    "icons": "Heroicons ou Lucide Icons",
    "font": "Inter"
  },
  "global_rules": {
    "language": "pt-BR",
    "style": "clean_saas_dashboard",
    "theme": "light",
    "rounded_style": "large rounded cards",
    "shadow_style": "soft shadows only",
    "layout_feeling": "profissional, espaçoso, confiável e moderno",
    "avoid": [
      "cores muito saturadas fora da paleta",
      "bordas grossas",
      "sombras pesadas",
      "textos pequenos demais",
      "layout poluído",
      "usar termos técnicos para usuário leigo"
    ]
  },
